+        "provider": provider,
+        "action": action,
+        "ok": ok,
+        "status_code": status_code,
+        "provider_txn_id": provider_txn_id,
+        "amount": amount,
+        "currency": currency,
+        "direction": direction,
+        "source_type": source_type,
+        "destination_type": destination_type,
+        "invoice_id": invoice_id,
+        "service_id": service_id,
+        "user_id": user_id,
+        "case_id": case_id,
+        "labor_order_id": labor_order_id,
+        "payload": payload or {},
+        "data": data or {},
+        "raw": raw or {},
