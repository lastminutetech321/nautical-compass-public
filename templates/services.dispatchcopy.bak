{% extends "base.html" %}
{% block title %}Services • Nautical Compass{% endblock %}

{% block content %}
<section class="page-shell">
  <div class="hero-card">
    <div class="eyebrow">Service Ports</div>
    <h1>Choose your lane</h1>
    <p class="muted">
      Enter through intake, review, labor intelligence, or remedy design. Each lane is built to support the current structure without replacing it.
    </p>
  </div>

  <div class="card-grid three-up" style="margin-top: 24px;">
    <a class="feature-card" href="/checkout">
      <div class="feature-kicker">Access</div>
      <h3>Get Access</h3>
      <p>Open the current live access and checkout path.</p>
      <span class="feature-link">Open Access →</span>
    </a>
  </div>
</section>
{% endblock %}
ard" href="/modules/signal-dock">
      <div class="feature-kicker">Issue Review</div>
      <h3>Signal Dock</h3>
      <p>Review the matter for notices, deadlines, contradictions, escalation points, and the practical signal pattern before further action.</p>
      <span class="feature-link">Open Signal Dock →</span>
    </a>

    <a class="feature-card" href="/modules/equity-engine">
      <div class="feature-kicker">Relief Strategy</div>
      <h3>Equity Engine</h3>
      <p>Shape remedy thinking, define posture, and organize the transition from intake review toward drafted relief and next-step leverage.</p>
      <span class="feature-link">Open Equity Engine →</span>
    </a>
  </div>

  <div class="card-grid three-up" style="margin-top: 24px;">
    <a class="feature-card" href="/modules/labor-signal">
      <div class="feature-kicker">Opportunity Mapping</div>
      <h3>Labor Signal</h3>
      <p>See demand lanes, role signals, skill gaps, and market routes. This is the visible front layer of the labor intelligence engine.</p>
      <span class="feature-link">Open Labor Signal →</span>
    </a>

    <a class="feature-card" href="/intake/production">
      <div class="feature-kicker">Operations</div>
      <h3>Production Command</h3>
      <p>Submit production-side logistics, scheduling, and labor demand so the wider system can route operator and workforce coverage.</p>
      <span class="feature-link">Open Production Command →</span>
    </a>

    <a class="feature-card" href="/intake/labor">
      <div class="feature-kicker">Workforce</div>
      <h3>Labor Dispatch</h3>
      <p>Submit labor-side readiness, certifications, market area, and availability to stage dispatch alignment and role coverage.</p>
      <span class="feature-link">Open Labor Dispatch →</span>
    </a>
  </div>
</section>
{% endblock %}
